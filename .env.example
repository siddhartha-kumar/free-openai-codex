# ---------------------------------------------------------------------------
# free-openai-codex - environment template
# Copy to .env and fill in only the providers you intend to use.
# Never commit a real .env. It is git-ignored.
# ---------------------------------------------------------------------------

# Gateway listener
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# Optional shared secret the gateway requires on inbound requests.
# Codex sends this as `Authorization: Bearer <key>` via OPENAI_API_KEY.
# Leave blank to disable inbound auth for local-only use.
GATEWAY_API_KEY=local-gateway-key

# --- Primary providers -----------------------------------------------------

# Ollama Cloud - OpenAI-compatible endpoint (https://ollama.com/v1)
OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com/v1

# Hugging Face router (hf-* and hf/* models)
HUGGINGFACE_API_KEY=
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# NVIDIA NIM (nim-* and nvidia/* models)
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Modal-hosted inference (modal-* models)
MODAL_API_KEY=
# MODAL_BASE_URL=https://api.us-west-2.modal.direct/v1

# Ollama local (ollama-local/*) needs no key by default.
# OLLAMA_LOCAL_BASE_URL=http://localhost:11434/api

# --- Optional OpenAI-style providers --------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
MOONSHOT_API_KEY=
ZAI_API_KEY=
